# Ativa o motor de reescrita de URL do Apache
RewriteEngine On

# Impede que os usuários listem o conteúdo das pastas
Options -Indexes

# [CORREÇÃO 1] Define a base do seu projeto com o case exato da URL
RewriteBase /TCC-AdotePatas/AdotePatas/

# --- REGRAS DE SEGURANÇA (Boas práticas, mantenha!) ---

# Bloqueia o acesso direto a arquivos de configuração sensíveis
<Files "conexao.php">
    Order allow,deny
    Deny from all
</Files>

# Protege o próprio arquivo .htaccess
<Files .htaccess>
    Order allow,deny
    Deny from all
</Files>

# --- REGRAS DE URL AMIGÁVEL ---

# Remove "index.php" da URL para manter a URL limpa
RewriteCond %{THE_REQUEST} ^[A-Z]{3,9}\ /index\.php\ HTTP/
RewriteRule ^index\.php$ / [R=301,L]

# Redireciona URLs amigáveis para a página de autenticação
RewriteRule ^login/?$ autenticacao.php?tab=login [NC,L]
RewriteRule ^cadastro/?$ autenticacao.php?tab=cadastro_usuario [NC,L]
RewriteRule ^cadastro-ong/?$ autenticacao.php?tab=cadastro_ong [NC,L]


# --- REGRAS PRINCIPAIS DE ROTEAMENTO ---

# [CORREÇÃO 2] Se o arquivo ou diretório solicitado EXISTIR, para de reescrever.
# Isso impede que a regra final capture URLs de arquivos válidos (como index.php, CSS, JS).
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Se a URL for a raiz, serve o index.php silenciosamente
RewriteRule ^$ index.php [L]

# [MELHORIA] Se nenhuma das regras acima corresponder, redireciona para a autenticação.
# Agora, esta regra só será acionada para URLs que realmente não existem.
RewriteRule . autenticacao.php [L]