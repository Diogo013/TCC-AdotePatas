# Ativa o motor de reescrita de URL do Apache
RewriteEngine On

# Impede que os usuários listem o conteúdo das pastas
Options -Indexes

# Define a base do seu projeto (AJUSTE CONFORME NECESSÁRIO!)
RewriteBase /TCC-AdotePatas/AdotePatas/

# --- REGRAS DE SEGURANÇA ---
<Files "conexao.php">
    Require all denied
</Files>
<Files ".htaccess">
    Require all denied
</Files>

# --- REGRAS DE URL AMIGÁVEL ---

# Remove "index.php" da URL
RewriteCond %{THE_REQUEST} ^[A-Z]{3,9}\ /index\.php\ HTTP/
RewriteRule ^index.php$ ./ [R=301,L] # Redireciona para a base

# URLs amigáveis para autenticacao.php
RewriteRule ^login/?$ autenticacao.php?tab=login [NC,L]
RewriteRule ^cadastro/?$ autenticacao.php?tab=cadastro_usuario [NC,L]
RewriteRule ^cadastro-ong/?$ autenticacao.php?tab=cadastro_ong [NC,L]

# <!-- REGRA ADICIONADA -->
# URL amigável para o cadastro de pet
RewriteRule ^cadastrar-pet/?$ cadastrar-pet.php [NC,L]


# --- REGRAS PRINCIPAIS DE ROTEAMENTO ---

# IGNORA ficheiros e diretórios existentes ANTES da regra final
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Regra para a raiz (serve index.php)
RewriteRule ^$ index.php [L]

# Regra final: Se não for ficheiro/diretório existente nem URL amigável,
# redireciona para autenticacao.php (como estava antes)
RewriteRule . autenticacao.php [L]
