# Ativa o motor de reescrita de URL do Apache
RewriteEngine On

# Define a base do seu projeto.
RewriteBase /TCC-ADOTEPATAS/adotepatas/

# --- REGRAS DE SEGURANÇA ---

# Impede que os usuários listem o conteúdo das pastas
Options -Indexes

# Bloqueia o acesso direto a arquivos de configuração sensíveis
<Files "conexao.php">
    Order allow,deny
    Deny from all
</Files>

# Protege o próprio arquivo .htaccess
<Files .htaccess>
    Order allow,deny
    Deny from all
</Files>

# --- REGRAS DE URL AMIGÁVEL ---

# --- INÍCIO DAS REGRAS ATUALIZADAS PARA O INDEX ---

# 1. Remove "index.php" da URL se ele for acessado diretamente
RewriteCond %{THE_REQUEST} ^[A-Z]{3,9}\ /(.*/)?index\.php\ HTTP/
RewriteRule ^((.*/)?index\.php)$ /$1 [R=301,L]

# 2. Permite que a URL raiz "/" carregue o arquivo index.php internamente
RewriteRule ^$ index.php [L]

# --- FIM DAS REGRAS ATUALIZADAS ---

# Redireciona "login" para a página de autenticação com a aba de login ativa
RewriteRule ^login/?$ autenticacao.php?tab=login [NC,L]

# Redireciona "cadastro" para a página de autenticação com a aba de cadastro ativa
RewriteRule ^cadastro/?$ autenticacao.php?tab=cadastro_usuario [NC,L]

# Redireciona "cadastro-ong" para a página de autenticação com a aba de ONG ativa
RewriteRule ^cadastro-ong/?$ autenticacao.php?tab=cadastro_ong [NC,L]


# --- REGRA GERAL (para arquivos e pastas existentes) ---

# Se o arquivo ou diretório solicitado não existir, redireciona para o autenticacao.php
# Isso permite que o JavaScript controle as rotas sem o servidor retornar erro 404
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule . autenticacao.php [L]